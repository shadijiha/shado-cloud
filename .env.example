# Environment
ENV=
APP_PORT= # port to listen to (optional)
REPLICATION_ROLE=
MASTER_OR_REPLICA_LOCAL_IP=

# App
CLOUD_DIR=
PASSWORD_VAULT_SALT=

# Cookies and auth
COOKIE_NAME=
JWT_SECRET=
BACKEND_HOST_NAME=localhost
FRONTEND_URL=
BACKEND_HOST=http://${BACKEND_HOST_NAME}/apinest


# Github webhooks
GITHUB_WEBHOOK_SECRET=
EMAIL_USER=
EMAIL_APP_PASSWORD=     # <--- This is not your gmail password. This is an APP password generate from Google account security
FRONTEND_DEPLOY_PATH=

# Database env
DB_TYPE=
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_NAME=

# DB Cache]
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
# Remote Desktop - set to :0 on Raspberry Pi, :99 for Docker/Xvfb testing
DISPLAY=:0

# Music Microservice
MUSIC_SERVICE_HOST=localhost
MUSIC_API_PORT=9001

# Gym Microservice (port 10001)
# NOTE: New microservices should use port = last microservice port + 1000
# This leaves room for existing microservices to claim additional ports if needed
# Current allocation: music=9001, gym=10001, next=11001
GYM_SERVICE_HOST=localhost
GYM_API_PORT=10001

# Auth Microservice (TCP port 11001)
AUTH_SERVICE_HOST=localhost
AUTH_API_PORT=11001
